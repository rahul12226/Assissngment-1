# Copy this file to ".env" and fill in your Binance Futures testnet credentials.
# The testnet uses fake funds -- never put real Binance keys here.
#
# Note on endpoints: Binance migrated the futures testnet. The standalone
# testnet.binancefuture.com site now redirects to demo.binance.com ("Demo
# Trading"). Both share the same /fapi API, so this bot works with either --
# just generate your keys on the site you can access and set the matching base
# URL below:
#
#   demo.binance.com            ->  https://demo-fapi.binance.com      (current)
#   testnet.binancefuture.com   ->  https://testnet.binancefuture.com  (classic)

BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_BASE_URL=https://demo-fapi.binance.com
